APP_NAME="Assumption College of Davao"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Manila

# Hostinger examples:
#   Main:      APP_URL=https://pantas.org
#   Subdomain: APP_URL=https://acd.pantas.org   (app in public_html/acd/, doc root public_html/acd/public)
# HOSTINGER_SUBDOMAIN=acd

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=acd_local
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Optional: first admin (php artisan db:seed --class=AdminUserSeeder)
ADMIN_EMAIL=admin@library.local
ADMIN_PASSWORD=password

# Optional: SMS modem bridge (local Flask server)
SMS_MODEM_URL=http://127.0.0.1:5000/send-sms
SMS_MODEM_API_KEY=your-secret-api-key

# Optional: custom branding CSS path under public/
# BRANDING_CSS=branding/branding.css
# Optional: bump after CSS deploy if CDN still shows old colors: BRANDING_ASSET_VERSION=2

# Optional: Hostinger subdomain folder name (see deploy/hostinger/README.md)
# HOSTINGER_SUBDOMAIN=acd

# Production (server only — do not use on local dev)
# APP_ENV=production
# APP_DEBUG=false
# SESSION_SECURE_COOKIE=true
